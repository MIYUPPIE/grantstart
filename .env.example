# GrantStar — Secret Keys
# DO NOT COMMIT THIS FILE TO VERSION CONTROL

# ── LLM Strategist (any OpenAI-compatible provider) ────────────────────────
# GrantStar works with ANY OpenAI-compatible chat endpoint. Set the key,
# base URL, and model for the provider you want. Examples:
#
#   xAI (Grok)    LLM_BASE_URL=https://api.x.ai/v1                LLM_MODEL=grok-2-latest
#   OpenAI        LLM_BASE_URL=https://api.openai.com/v1          LLM_MODEL=gpt-4o
#   Groq          LLM_BASE_URL=https://api.groq.com/openai/v1     LLM_MODEL=llama-3.3-70b-versatile
#   OpenRouter    LLM_BASE_URL=https://openrouter.ai/api/v1       LLM_MODEL=anthropic/claude-3.5-sonnet
#   Gemini        LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  LLM_MODEL=gemini-2.0-flash
#   Ollama (local) LLM_BASE_URL=http://localhost:11434/v1         LLM_MODEL=llama3.1   (any non-empty key)
LLM_API_KEY=
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-2-latest
# Optional sampling temperature (default 0.7)
LLM_TEMPERATURE=0.7

# Legacy fallback — still honored if LLM_API_KEY is empty.
# XAI_API_KEY=

# Flask Secret Key for sessions
SECRET_KEY=
